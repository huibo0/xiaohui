# ========== 基础配置 ==========
SITE_URL=https://xiaohui.sdfeer.site
TZ=Asia/Shanghai

# 数据库文件路径（默认 ./data/xiaohui.db）
DB_PATH=./data/xiaohui.db

# 状态查看密钥（你查看她吃药情况用的）
STATUS_KEY=xiaohui2026

# ========== 吃药时间 ==========
MORNING_TIME=08:00
EVENING_TIME=20:00
# 提醒后多少分钟检查（未吃则通知你）
CHECK_DELAY_MINUTES=30

# ========== 微信公众号推送 ==========
WECHAT_APPID=wx1234567890abcdef
WECHAT_APPSECRET=your_app_secret_here
WECHAT_TEMPLATE_ID=your_template_id_here

# 你妻子的 OpenID（关注公众号后获取）
WECHAT_OPENID=oXXXX_wife_openid

# 你的 OpenID（她没吃药时通知你）
WECHAT_OPENID_HUSBAND=oXXXX_husband_openid
